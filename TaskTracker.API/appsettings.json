{
  "ConnectionStrings": {
    "DefaultConnection": "Host=YourHost;Database=YourDatabase;Username=YourUsername;Password=YourPasswordHere"
  },
  "JwtSettings": {
    "SecretKey": "YourSuperSecretKeyHereThatIsAtLeast32CharactersLong!!",
    "Issuer": "TaskTracker",
    "Audience": "TaskTrackerUsers",
    "AccessTokenExpirationMinutes": "your_value_here",
    "RefreshTokenExpirationDays": "your_value_here"
  },
  "OtpSettings": {
    "ExpiryMinutes": "your_value_here",
    "MaxAttempts": "your_value_here",
    "MaxResends": "your_value_here",
    "ResendCooldownSeconds": "your_value_here",
    "HashKey": "YourOtpHashKeyHereThatIsSecure!!"
  },
  "SmtpSettings": {
    "Host": "your_smtp_host_here",
    "Port": "your_smtp_port_here",
    "UseSsl": true,
    "Username": "your_smtp_username_here",
    "Password": "your_smtp_password_here",
    "SenderEmail": "your_sender_email_here",
    "SenderName": "your_sender_name_here"
  },
  "AdminSeed": {
    "Enabled": true,
    "Email": "your_admin_email_here",
    "Password": "your_admin_password_here",
    "FirstName": "Super",
    "LastName": "Admin"
  },
  "TaskDateRules": {
    "DefaultSprintDurationDays": 10,
    "AllowedEndDateExtensionDays": [ 1, 5, 10 ]
  },
  "Invite": {
    "ExpirationDays": 7,
    "AcceptUrl": "your_frontend_url_here"
  },
  "NotificationSettings": {
    "DueSoonWindowHours": "your_value_here",
    "DueDateMonitorIntervalMinutes": "your_value_here",
    "RetentionCountPerUser": "your_value_here"
  },
  "IdentitySettings": {
    "LockoutMinutes": "your_value_here",
    "MaxFailedAccessAttempts": "your_value_here"
  },
  "Cloudinary": {
    "CloudName": "your_cloud_name",
    "ApiKey": "your_api_key",
    "ApiSecret": "your_api_secret"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Information"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": "your_value_here",
          "shared": true,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "CacheSettings": {
    "UserStatusSlidingMinutes": "your_value_here",
    "UserStatusAbsoluteMinutes": "your_value_here",
    "SuperAdminSlidingMinutes": "your_value_here",
    "SuperAdminAbsoluteMinutes": "your_value_here",
    "PermissionsSlidingMinutes": "your_value_here",
    "PermissionsAbsoluteMinutes": "your_value_here",
    "MembershipIdsSlidingMinutes": "your_value_here",
    "MembershipIdsAbsoluteMinutes": "your_value_here",
    "RoleInScopeSlidingMinutes": "your_value_here",
    "RoleInScopeAbsoluteMinutes": "your_value_here",
    "ResourceScopeSlidingMinutes": "your_value_here",
    "ResourceScopeAbsoluteMinutes": "your_value_here",
    "ProjectMetadataSlidingMinutes": "your_value_here",
    "ProjectMetadataAbsoluteMinutes": "your_value_here"
  }
}